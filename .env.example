# ==============================================================================
# Linux Cowork Agent (Open Cowork) Environment Configuration
# ==============================================================================

# 1. LLM API Keys (Provide at least one if you intend to run live LLM agents)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 2. Local Ollama Server url (if running Ollama models on host machine)
# Under Linux/Docker bridge network, use the gateway ip to refer to host
OLLAMA_API_BASE=http://172.17.0.1:11434

# 3. Port configurations (Optional, default settings match docker-compose)
FRONTEND_PORT=3000
BACKEND_PORT=8000
SANDBOX_API_PORT=5001
SANDBOX_VNC_PORT=6080
